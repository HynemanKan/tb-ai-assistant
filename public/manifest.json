{
  "manifest_version": 2,
  "version": "1.0",
  "author": "Hyneman Kan",
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self';",
  "browser_specific_settings": {
    "gecko": {
      "id": "tb-ai-assistant@hynemankan.top",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["accountsRead","messagesRead","messagesUpdate","messagesTags","storage"],
  "experiment_apis": {
    "FileSystem": {
      "schema": "api/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["FileSystem"]],
        "script": "api/implementation.js"
      }
    }
  },
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true,
    "browser_style": true
  },
  "default_locale": "en"
}
