{
  "manifest_version": 2,
  "version": "1.2.14",
  "author": "Hyneman Kan",
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self';",
  "browser_specific_settings": {
    "gecko": {
      "id": "tb-ai-assistant@hynemankan.top",
      "strict_min_version": "128.0",
      "strict_max_version": "136.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["accountsRead","messagesRead","messagesUpdate","messagesTags","storage"],
  "experiment_apis": {
    "calendar_calendars": {
      "schema": "experiments/calendar/schema/calendar-calendars.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-calendars.js",
        "paths": [
          ["calendar", "calendars"]
        ]
      }
    },
    "calendar_items": {
      "schema": "experiments/calendar/schema/calendar-items.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-items.js",
        "paths": [
          ["calendar", "items"]
        ]
      }
    },
    "calendar_provider": {
      "schema": "experiments/calendar/schema/calendar-provider.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-provider.js",
        "events": ["startup"],
        "paths": [
          ["calendar", "provider"]
        ]
      }
    },
    "calendar_timezones": {
      "schema": "experiments/calendar/schema/calendar-timezones.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendar-timezones.js",
        "paths": [
          ["calendar", "timezones"]
        ]
      },
      "child": {
        "scopes": ["addon_child"],
        "script": "experiments/calendar/child/ext-calendar-timezones.js",
        "paths": [
          ["calendar", "timezones"]
        ]
      }
    },
    "calendarItemAction": {
      "schema": "experiments/calendar/schema/calendarItemAction.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendarItemAction.js",
        "events": ["startup"],
        "paths": [
          ["calendarItemAction"]
        ]
      }
    },
    "calendarItemDetails": {
      "schema": "experiments/calendar/schema/calendarItemDetails.json",
      "parent": {
        "scopes": ["addon_parent"],
        "script": "experiments/calendar/parent/ext-calendarItemDetails.js",
        "events": ["startup"],
        "paths": [
          ["calendarItemDetails"]
        ]
      }
    }
  },
  "options_ui": {
    "page": "index.html",
    "open_in_tab": true,
    "browser_style": true
  },

  "default_locale": "en"
}
